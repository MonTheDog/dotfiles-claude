#!/bin/bash
# Altair — Claude Code with Altair skin and identity

# Show Altair banner as pre-launch splash
clear
~/.claude/skins/engine/show-banner.sh altair

# Brief pause so the banner is visible, then clear before Claude Code starts
sleep 1.5
clear

ALTAIR_SKIP_HOOK_BANNER=1 CLAUDE_SKIN_OVERRIDE=altair exec claude "$@"
