#!/bin/bash
# Altair — Claude Code with Altair skin and identity
# Background job: waits for Claude Code's TUI to draw, then clears and shows Altair banner
(
  sleep 0.8
  printf '\033[2J\033[H' > /dev/tty 2>/dev/null
  ~/.claude/skins/engine/show-banner.sh altair > /dev/tty 2>/dev/null
) &

CLAUDE_SKIN_OVERRIDE=altair exec claude "$@"
